{
    "name": "pearlbrains/native-patches",
    "description": "NativePHP Mobile build-time patches for (Android + iOS)",
    "type": "nativephp-plugin",
    "autoload": {
        "psr-4": {
            "Pearlbrains\\NativePatches\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Pearlbrains\\NativePatches\\NativePatchesServiceProvider"
            ]
        }
    },
    "require": {
        "php": "^8.3",
        "illuminate/support": "^12.0 || ^13.9",
        "nativephp/mobile": "^3.0"
    }
}
